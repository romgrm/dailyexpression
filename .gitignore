# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Flutter version management (FVM)
.fvm/
.fvmrc

# Generated localization output (regenerated by gen-l10n on build)
lib/l10n/generated/

# Coverage reports
coverage/
*.lcov

# Golden-test failure diffs (regenerated on every failing run; never commit)
**/failures/

# Secrets & environment files (never commit credentials)
*.env
.env
.env.*
!.env.example
*.keystore
*.jks
key.properties
ios/Runner/GoogleService-Info.plist
android/app/google-services.json
**/*.p8
**/*.p12
**/*.mobileprovision
**/*.certSigningRequest

# Native build safety nets (also covered by ios/ & android/ .gitignore)
**/android/local.properties
**/android/key.properties
**/ios/Flutter/Generated.xcconfig
**/ios/Flutter/flutter_export_environment.sh
**/ios/Pods/
**/ios/.symlinks/
**/macos/Pods/
**/macos/Flutter/GeneratedPluginRegistrant.swift

# macOS / editor cruft
.DS_Store
**/.DS_Store
*.pdb
*.iml.bak
.vscode/*.log
